# Copy this to secrets.toml and fill in your service account JSON fields.
# secrets.toml is gitignored — never commit it.
# On Streamlit Community Cloud, paste the JSON contents in the Secrets UI instead.

[gcp_service_account]
type = "service_account"
project_id = "f1-analytics-pipeline"
private_key_id = "..."
private_key = "-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n"
client_email = "...@f1-analytics-pipeline.iam.gserviceaccount.com"
client_id = "..."
auth_uri = "https://accounts.google.com/o/oauth2/auth"
token_uri = "https://oauth2.googleapis.com/token"
